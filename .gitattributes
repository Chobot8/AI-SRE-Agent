# Normalize line endings: store everything as LF in the repo.
# Prevents CRLF/LF churn and the "LF will be replaced by CRLF" warnings.
* text=auto eol=lf

# Source & text files — always LF
*.py    text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.txt   text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sh    text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf
.env.example   text eol=lf

# Binary files — never touch
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.pdf   binary
*.ico   binary
*.skill binary
