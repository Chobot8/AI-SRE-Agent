# Copy this file to .env and fill in real values locally.
# .env is gitignored — never commit real secrets.

# --- Service ---
APP_NAME=AI SRE Agent
ENVIRONMENT=local
DEBUG=true

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- LLM provider (placeholders) ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Vector store (used from KAN-4 onward) ---
VECTOR_STORE_URL=
