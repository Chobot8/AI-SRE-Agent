# Copy this file to .env and fill in real values locally.
# .env is gitignored -- never commit real secrets.

# --- Service ---
APP_NAME=AI SRE Agent
ENVIRONMENT=local
DEBUG=true

# --- Observability (KAN-12) ---
LOG_LEVEL=INFO
LOG_FORMAT=json   # "json" for structured logs, or "text" for human-readable

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- LLM provider (placeholders) ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Vector store (used from KAN-4 onward) ---
VECTOR_STORE_URL=

# --- PostgreSQL persistence (KAN-15) ---
# Used by the docker-compose `db` service and the backend persistence layer.
# These are LOCAL DEV defaults only -- never commit real credentials.
POSTGRES_USER=sre
POSTGRES_PASSWORD=sre_local_dev
POSTGRES_DB=ai_sre
# Full SQLAlchemy URL. The default host is the docker-compose service name `db`,
# matching infra/docker-compose.yml so `docker compose up` works with a copied
# .env. For host-local dev (API outside Docker), change the host to localhost.
DATABASE_URL=postgresql+psycopg://sre:sre_local_dev@db:5432/ai_sre

# --- UI (Streamlit) ---
# Backend API base URL the UI calls. For docker-compose use the service name
# (http://api:8000); for local dev the default below is correct.
BACKEND_API_URL=http://localhost:8000

# --- SRE tool connectors (KAN-22) ---
# All optional and unset by default. The mock connectors (used everywhere in
# this demo) need none of these. Fill one in only to point that connector at a
# real system -- see backend/connectors/README.md for what each does.
PROMETHEUS_BASE_URL=
PROMETHEUS_TIMEOUT_SECONDS=5

LOKI_BASE_URL=
LOKI_TIMEOUT_SECONDS=5

KUBERNETES_API_BASE_URL=
KUBERNETES_BEARER_TOKEN=
KUBERNETES_VERIFY_TLS=true
KUBERNETES_TIMEOUT_SECONDS=5

JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_TIMEOUT_SECONDS=5

RUNBOOK_SOURCE_BASE_URL=
RUNBOOK_SOURCE_API_TOKEN=
RUNBOOK_TIMEOUT_SECONDS=5
