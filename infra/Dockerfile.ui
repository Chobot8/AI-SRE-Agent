# syntax=docker/dockerfile:1
#
# UI image for the AI SRE Agent (KAN-10).
# Builds the Streamlit incident-triage demo. The UI is a thin HTTP client of the
# backend API, so it only needs the ui/ package and shared dependencies.

FROM python:3.11-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

# Install dependencies first so the layer is cached across code changes.
COPY requirements.txt ./
RUN pip install -r requirements.txt

# Application code.
COPY ui ./ui

# Run as an unprivileged user.
RUN useradd --create-home --uid 10001 appuser \
    && chown -R appuser:appuser /app
USER appuser

# Externalized configuration — overridable via env / docker-compose.
# BACKEND_API_URL points the UI at the API service (compose service name by default).
ENV BACKEND_API_URL=http://api:8000 \
    STREAMLIT_SERVER_PORT=8501 \
    STREAMLIT_SERVER_ADDRESS=0.0.0.0 \
    STREAMLIT_SERVER_HEADLESS=true \
    STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

EXPOSE 8501

# Container-level liveness probe against Streamlit's built-in health endpoint.
HEALTHCHECK --interval=15s --timeout=5s --start-period=20s --retries=5 \
    CMD ["python", "-c", "import urllib.request,sys; sys.exit(0) if urllib.request.urlopen('http://127.0.0.1:8501/_stcore/health', timeout=3).status==200 else sys.exit(1)"]

# Clean startup command. Server host/port are read from the STREAMLIT_* env vars.
CMD ["streamlit", "run", "ui/app.py"]
