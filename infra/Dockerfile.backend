# syntax=docker/dockerfile:1
#
# Backend API image for the AI SRE Agent (KAN-10).
# Builds the FastAPI service that exposes the health + diagnosis endpoints.
# The RAG vector store is built in-process from knowledge/runbooks at request
# time, so no separate vector-database container is required.

FROM python:3.11-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

# Install dependencies first so the layer is cached across code changes.
COPY requirements.txt ./
RUN pip install -r requirements.txt

# Application code + data the backend needs at runtime.
COPY pyproject.toml ./
COPY backend ./backend
COPY knowledge ./knowledge
COPY sample-data ./sample-data

# Run as an unprivileged user; pre-create the writable telemetry dir.
RUN useradd --create-home --uid 10001 appuser \
    && mkdir -p /app/data \
    && chown -R appuser:appuser /app
USER appuser

# Externalized configuration — overridable via env / docker-compose.
ENV HOST=0.0.0.0 \
    PORT=8000

EXPOSE 8000

# Container-level liveness probe against the FastAPI /health endpoint.
HEALTHCHECK --interval=15s --timeout=5s --start-period=20s --retries=5 \
    CMD ["python", "-c", "import os,urllib.request,sys; sys.exit(0) if urllib.request.urlopen('http://127.0.0.1:'+os.environ.get('PORT','8000')+'/health', timeout=3).status==200 else sys.exit(1)"]

# Clean startup command. HOST/PORT come from the environment.
CMD ["sh", "-c", "uvicorn backend.main:app --host ${HOST:-0.0.0.0} --port ${PORT:-8000}"]
