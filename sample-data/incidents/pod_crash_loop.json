{
  "id": "INC-1003",
  "scenario": "pod_crash_loop",
  "service": "recommendation-worker",
  "environment": "production",
  "alert": {
    "source": "alertmanager",
    "severity": "warning",
    "summary": "recommendation-worker pod restarting (CrashLoopBackOff), 7 restarts in 12m",
    "started_at": "2026-06-24T03:02:00Z",
    "labels": {
      "service": "recommendation-worker",
      "namespace": "ml",
      "reason": "CrashLoopBackOff"
    }
  },
  "metrics": [
    {
      "name": "pod_restarts_total",
      "unit": "count",
      "description": "Cumulative container restarts",
      "points": [
        { "t": "2026-06-24T02:50:00Z", "value": 0 },
        { "t": "2026-06-24T02:55:00Z", "value": 2 },
        { "t": "2026-06-24T03:00:00Z", "value": 5 },
        { "t": "2026-06-24T03:05:00Z", "value": 7 }
      ]
    },
    {
      "name": "container_memory_usage_bytes",
      "unit": "bytes",
      "description": "Memory usage vs 512Mi limit (536870912 bytes)",
      "points": [
        { "t": "2026-06-24T02:59:30Z", "value": 402653184 },
        { "t": "2026-06-24T02:59:50Z", "value": 503316480 },
        { "t": "2026-06-24T03:00:05Z", "value": 536870912 }
      ]
    }
  ],
  "logs": [
    { "t": "2026-06-24T03:00:06Z", "level": "FATAL", "service": "recommendation-worker", "message": "Container killed: OOMKilled (exceeded memory limit 512Mi)" },
    { "t": "2026-06-24T03:00:08Z", "level": "INFO", "service": "kubelet", "message": "Back-off restarting failed container recommendation-worker" },
    { "t": "2026-06-24T03:01:14Z", "level": "WARN", "service": "recommendation-worker", "message": "loading full embedding matrix into memory (1.2M rows) at startup" }
  ],
  "expected_root_cause": {
    "summary": "The worker is OOMKilled at startup because it loads the full embedding matrix into memory, exceeding the 512Mi limit, producing a CrashLoopBackOff. Raising the memory limit or streaming/lazy-loading the embeddings resolves it.",
    "category": "oom_kill",
    "key_signals": [
      "memory usage hits the 512Mi limit immediately before each restart",
      "log: OOMKilled",
      "restart count climbs in a tight loop (CrashLoopBackOff)"
    ],
    "runbook_references": [
      "pod_crash_loop.md"
    ]
  }
}
